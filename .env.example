# Opensearch connection string, including scheme, host, port, and credentials if needed.
# Example: https://user:pass@opensearch.example.com:9200
OPENSEARCH_URL=

# Absolute or relative path to the directory containing the 4 .xlsx files.
DATA_DIR=./data

# Name of the Opensearch index to query.
OPENSEARCH_INDEX=

# Field on the indexed document whose value is the supplier ID used for retrieval.
OPENSEARCH_ID_FIELD=
